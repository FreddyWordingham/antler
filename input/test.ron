(
  assets_dir: "assets",
  output_dir: "output",
  lighting_settings: (
    emitted: 1.0,
    ambient: 1.0,
    direct: 1.0,
    indirect: 1.0
  ),
  probe_settings: (
    max_generation: 5,
    min_weight: 1.0e-2
  ),
  scenes: {
    "my_scene": (
      ambient: 0x333333,
      occlusion: Some((
        samples: 64,
        distance: 1.0,
        strength: 1.0e1,
        falloff: 2.0,
      )),
      lights: [
        Directional (
          direction: (2.0, -2.5, -1.0),
          radiance: 0xFFFFFF,
          angular_radius: Some(5.0),
          samples: Some(64)
        )
      ],
      objects: [
        @include("input/spheres.ron"),
        @include("input/pyramids.ron"),

        (
          geometry: Mesh ( path: "assets/meshes/puddle.obj" ),
          material: Reflective (
            reflectance: 0.5
          ),
          shader: Solid ( colour: 0x00FFCC ),
          transform: (
            translation: (15.0, 12.0, 0.01),
            rotation: (0.0, 0.0, 140.0),
            scale: 7.0
          )
        ),
        (
          geometry: Mesh ( path: "assets/meshes/puddle.obj" ),
          material: Reflective (
            reflectance: 0.5
          ),
          shader: Solid ( colour: 0x00FFCC ),
          transform: (
            translation: (-15.0, 8.0, 0.01),
            rotation: (0.0, 0.0, 210.0),
            scale: 5.0
          )
        ),
        (
          geometry: Mesh ( path: "assets/meshes/puddle.obj" ),
          material: Reflective (
            reflectance: 0.5
          ),
          shader: Solid ( colour: 0x00FFCC ),
          transform: (
            translation: (0.0, -16.0, 0.01),
            rotation: (0.0, 0.0, 290.0),
            scale: 6.0
          )
        ),

        (
          geometry: Mesh ( path: "assets/meshes/golem.obj" ),
          material: Opaque,
          shader: Gradient ( gradient: [0xFF0000, 0xFFFF00], power: 1.0 ),
          transform: (
            scale: 4.0,
            translation: (0.0, 0.0, 0.0),
            rotation: (0.0, 0.0, 150.0)
          )
        ),
        (
          geometry: Circle (
            centre: (0.0, 0.0, -1.0e-3),
            radius: 6.0e1
          ),
          material: Opaque,
          shader: Checkerboard (
            size: 1.0,
            colour_a: 0x00DD00,
            colour_b: 0x00AA00
          )
        )
      ],
      captures: {
        "my_capture": (
          camera: Perspective (
            position: (1.0e1, 1.0e1, 4.0),
            look_at: (0.0, 0.0, 2.5),
            vertical_fov: 55.0
          ),
          images: {
            "my_image": (
              resolution: (5120, 1440),
              super_samples: 1
            )
          }
        )
      }
    )
  }
)
